{
	"name": "@openai-oauth/web",
	"version": "2.0.0-beta.3",
	"description": "Browser credential storage and web utilities for openai-oauth.",
	"keywords": [
		"openai",
		"oauth",
		"chatgpt",
		"codex",
		"browser",
		"web"
	],
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js",
			"default": "./dist/server.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
		"prepublishOnly": "bun run build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@openai-oauth/core": "workspace:*"
	},
	"devDependencies": {
		"fake-indexeddb": "6.2.5",
		"typescript": "5.9.2",
		"vitest": "4.1.10"
	},
	"author": "EvanZhouDev",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EvanZhouDev/openai-oauth.git",
		"directory": "packages/web"
	},
	"bugs": {
		"url": "https://github.com/EvanZhouDev/openai-oauth/issues"
	},
	"homepage": "https://github.com/EvanZhouDev/openai-oauth#readme"
}
