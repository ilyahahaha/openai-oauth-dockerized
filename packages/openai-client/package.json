{
	"name": "@openai-oauth/openai-client",
	"version": "2.0.0",
	"description": "OpenAI JavaScript SDK adapter for openai-oauth auth handles.",
	"keywords": [
		"openai",
		"oauth",
		"chatgpt",
		"codex",
		"openai-client"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "bun run build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@openai-oauth/core": "workspace:*"
	},
	"devDependencies": {
		"typescript": "latest",
		"vitest": "latest"
	},
	"author": "EvanZhouDev",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EvanZhouDev/openai-oauth.git",
		"directory": "packages/openai-client"
	},
	"bugs": {
		"url": "https://github.com/EvanZhouDev/openai-oauth/issues"
	},
	"homepage": "https://github.com/EvanZhouDev/openai-oauth#readme"
}
